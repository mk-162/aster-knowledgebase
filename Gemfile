# Knowledge-base site dependencies.
#
#   bundle install
#   bundle exec jekyll serve     # local preview at http://localhost:4000
source "https://rubygems.org"

gem "jekyll", "~> 4.3"
gem "just-the-docs", "~> 0.10"   # the theme
gem "jekyll-relative-links"      # makes the .md links between articles resolve on the built site

# Ruby 3.4+ no longer ships these as default gems
gem "webrick", "~> 1.9"
gem "csv"
gem "base64"
gem "bigdecimal"
